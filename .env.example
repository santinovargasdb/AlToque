# ─────────────────────────────────────────────────────────────
# AlToque — Variables de entorno (placeholders)
# Copiar a .env.local y completar. NUNCA commitear .env*.
# Las variables se validan con Zod al iniciar (src/lib/env.ts).
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Postgres (pooler de Supabase) — Supabase → Settings → Database
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres"

# Supabase — Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE-ROLE-KEY]"   # SOLO server. Nunca exponer al cliente.

# Mercado Pago — Mercado Pago → Tus integraciones (App Marketplace)
MP_CLIENT_ID="[MP-CLIENT-ID]"
MP_CLIENT_SECRET="[MP-CLIENT-SECRET]"
MP_ACCESS_TOKEN="[MP-ACCESS-TOKEN]"               # Cuenta marketplace (la tuya)
NEXT_PUBLIC_MP_PUBLIC_KEY="[MP-PUBLIC-KEY]"
MP_WEBHOOK_SECRET="[MP-WEBHOOK-SECRET]"           # Para validar firma x-signature

# Google Maps Platform — Google Cloud Console
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="[MAPS-BROWSER-KEY]"   # Restringida por dominio (Maps JS + Places)
GOOGLE_MAPS_SERVER_KEY="[MAPS-SERVER-KEY]"             # Geocoding server-side

# Email transaccional — Resend
RESEND_API_KEY="[RESEND-API-KEY]"

# Web Push (VAPID) — generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="[VAPID-PUBLIC-KEY]"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="[VAPID-PUBLIC-KEY]"      # Misma clave pública, expuesta al navegador
VAPID_PRIVATE_KEY="[VAPID-PRIVATE-KEY]"

# Cron — protege /api/cron/*
CRON_SECRET="[GENERAR-UN-SECRETO]"

# Comisión por defecto del marketplace (snapshot al crear el job)
COMMISSION_RATE="0.12"
